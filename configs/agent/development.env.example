# Edge agent environment (copy to .env on each web_server node)

# Control plane base URL (no trailing slash)
SDKWORK_WEB_CONTROL_PLANE_URL=http://127.0.0.1:3800

# Bootstrap token from POST /backend/v3/api/servers (returned once as agentToken)
SDKWORK_WEB_AGENT_TOKEN=wagent_replace_me

# Sync interval in seconds
SDKWORK_WEB_AGENT_SYNC_INTERVAL_SECS=30

# Local state file for last applied syncVersion (offline compensation on reconnect)
# SDKWORK_WEB_AGENT_STATE_PATH=/var/lib/sdkwork-web-agent/state.json
# SDKWORK_WEB_AGENT_STATE_DIR=/var/lib/sdkwork-web-agent

# Local nginx + certificate paths (see sdkwork-webserver-edge-runtime)
SDKWORK_WEB_NGINX_ENABLED=true
SDKWORK_WEB_NGINX_SITES_ROOT=/etc/nginx/sites-enabled/sdkwork
SDKWORK_WEB_CERT_LIVE_ROOT=/opt/certs/letsencrypt/live
