SDKWORK_WEB_DEPLOYMENT_PROFILE=cloud
SDKWORK_WEB_SERVICE_LAYOUT=unified-process
SDKWORK_WEB_ENVIRONMENT=development
SDKWORK_WEB_PROFILE_ID=cloud.unified-process.development
SDKWORK_WEB_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:3800
SDKWORK_WEB_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:3800
SDKWORK_WEB_APPLICATION_APP_HTTP_BIND=127.0.0.1:3800
SDKWORK_WEB_APPLICATION_APP_HTTP_URL=http://127.0.0.1:3800/app/v3/api
SDKWORK_WEB_APPLICATION_BACKEND_HTTP_BIND=127.0.0.1:3800
SDKWORK_WEB_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:3800/backend/v3/api
SDKWORK_WEB_DATABASE_ENGINE=sqlite
SDKWORK_WEB_DATABASE_URL=sqlite://./.sdkwork/local/web-development.db
SDKWORK_WEB_DATABASE_AUTO_MIGRATE=true
SDKWORK_WEB_DEV_AUTH_BYPASS=true
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.web.development.toml
