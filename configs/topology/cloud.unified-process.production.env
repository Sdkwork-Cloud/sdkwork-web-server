SDKWORK_WEB_DEPLOYMENT_PROFILE=cloud
SDKWORK_WEB_SERVICE_LAYOUT=unified-process
SDKWORK_WEB_ENVIRONMENT=production
SDKWORK_WEB_PROFILE_ID=cloud.unified-process.production
SDKWORK_WEB_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:3800
SDKWORK_WEB_APPLICATION_PUBLIC_HTTP_URL=https://web.sdkwork.com
SDKWORK_WEB_APPLICATION_APP_HTTP_URL=https://web-app.sdkwork.com/app/v3/api
SDKWORK_WEB_APPLICATION_BACKEND_HTTP_URL=https://web-admin.sdkwork.com/backend/v3/api
SDKWORK_WEB_DATABASE_ENGINE=postgres
SDKWORK_WEB_DATABASE_AUTO_MIGRATE=true
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.web.production.toml
