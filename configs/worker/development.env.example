# Certificate renewal worker (copy to .env on control plane host)

# Scan interval in seconds (default 3600 = 1 hour)
SDKWORK_WEB_CERT_RENEW_SCAN_INTERVAL_SECS=3600

# Days before not_after to trigger renewal (default 30)
SDKWORK_WEB_CERT_RENEW_BEFORE_DAYS=30

# Shared with api-server / acme-service
SDKWORK_WEB_CERT_ENCRYPTION_KEY=sdkwork-web-development-cert-key
SDKWORK_WEB_ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory
SDKWORK_WEB_ACME_WEBROOT=/var/www/acme-challenge
SDKWORK_WEB_CERT_LIVE_ROOT=/opt/certs/letsencrypt/live
SDKWORK_WEB_NGINX_SITES_ROOT=/etc/nginx/sites-enabled/sdkwork
