{
  "schemaVersion": 1,
  "kind": "sdkwork.webserver.app",
  "appKey": "sdkwork-example-web",
  "compatibility": {
    "nginxProfile": "http-core-v1",
    "unknownDirectivePolicy": "error"
  },
  "limits": {
    "maxRequestBodyBytes": 10485760,
    "requestTimeoutMs": 30000,
    "requestBodyStartTimeoutMs": 30000,
    "requestBodyIdleTimeoutMs": 30000,
    "responseBodyIdleTimeoutMs": 30000,
    "connectionWriteTimeoutMs": 30000,
    "http1KeepAliveIdleTimeoutMs": 75000,
    "http1MaxPipelineDepth": 16,
    "drainTimeoutMs": 30000,
    "maxConnections": 10000,
    "maxConcurrentRequests": 4096,
    "maxRequestHeaderBytes": 65536,
    "maxRequestLineBytes": 8192,
    "maxRequestMethodBytes": 32,
    "maxRequestTargetBytes": 8192,
    "maxUriPathBytes": 8192,
    "maxDecodedPathBytes": 8192,
    "maxPathSegments": 256,
    "maxQueryStringBytes": 4096,
    "maxQueryParameters": 256,
    "maxQueryComponentBytes": 1024,
    "maxHeaderNameBytes": 256,
    "maxHeaderValueBytes": 8192,
    "maxRequestHeaders": 100,
    "requestHeaderTimeoutMs": 10000,
    "maxChunkLineBytes": 1024,
    "maxTrailerBytes": 8192,
    "maxTrailers": 32,
    "http2MaxConcurrentStreams": 100,
    "maxConnectionAgeMs": 3600000,
    "http2KeepAliveIntervalMs": 60000,
    "http2KeepAliveTimeoutMs": 20000,
    "http2MaxPendingAcceptResetStreams": 20,
    "http2MaxLocalErrorResetStreams": 128,
    "http2MaxSendBufferBytes": 65536,
    "http2MaxHeaderListBytes": 65536,
    "http2MaxFrameBytes": 16384,
    "http2AbuseWindowMs": 1000,
    "http2MaxFramesPerWindow": 10000,
    "http2MaxNewStreamsPerWindow": 1000,
    "http2MaxResetFramesPerWindow": 100,
    "http2MaxContinuationFrames": 16,
    "http2MaxEncodedHeaderBlockBytes": 65536
  },
  "listeners": [
    {
      "id": "public-http",
      "bind": "127.0.0.1",
      "port": 8080,
      "protocols": ["http1"],
      "defaultVirtualHostRef": "example-web"
    }
  ],
  "certificates": [],
  "tlsPolicies": [],
  "resolvers": [],
  "resources": [
    {
      "id": "health-response",
      "type": "respond",
      "status": 200,
      "contentType": "text/plain; charset=utf-8",
      "body": "ok\n"
    },
    {
      "id": "web-static",
      "type": "static",
      "root": "public",
      "indexFiles": ["index.html"],
      "spaFallback": "index.html",
      "followSymlinks": false
    }
  ],
  "upstreams": [],
  "virtualHosts": [
    {
      "id": "example-web",
      "listenerRefs": ["public-http"],
      "serverNames": ["localhost"],
      "routes": [
        {
          "id": "health",
          "match": {
            "pathType": "exact",
            "path": "/healthz",
            "methods": ["GET", "HEAD"]
          },
          "resourceRef": "health-response"
        },
        {
          "id": "web",
          "match": {
            "pathType": "prefix",
            "path": "/"
          },
          "resourceRef": "web-static"
        }
      ]
    }
  ],
  "observability": {
    "accessLog": true
  },
  "deployment": {
    "drainTimeoutMs": 30000,
    "reload": {
      "mode": "watch",
      "pollIntervalMs": 1000
    }
  },
  "metadata": {
    "owner": "sdkwork"
  }
}
