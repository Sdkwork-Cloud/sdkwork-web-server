{
  "name": "sdkwork-web-workspace",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "tar": "7.5.20",
    "yaml": "^2.8.0"
  },
  "scripts": {
    "dev": "pnpm dev:standalone",
    "dev:standalone": "pnpm dev:browser:postgres:standalone",
    "dev:cloud": "node scripts/webserver-cloud-dev.mjs --deployment-profile cloud --environment development",
    "dev:browser": "pnpm dev:browser:postgres:standalone",
    "dev:browser:postgres": "pnpm dev:browser:postgres:standalone",
    "dev:browser:postgres:standalone": "node scripts/webserver-im-dev.mjs --config etc/sdkwork.webserver.im-dev.json --database postgres --deployment-profile standalone --environment development",
    "dev:server": "pnpm dev:server:postgres:standalone",
    "dev:server:postgres": "pnpm dev:server:postgres:standalone",
    "dev:server:postgres:standalone": "node scripts/webserver-dev.mjs --database postgres --deployment-profile standalone --environment development --dev-env-file .env.postgres",
    "dev:server:sqlite": "node scripts/webserver-dev.mjs --database sqlite --deployment-profile standalone --environment development",
    "stop": "node ../sdkwork-specs/tools/stop-sdkwork-workspace-processes.mjs --workspace .",
    "build": "cargo build --workspace --release",
    "build:app": "node scripts/workspace-app-command.mjs build",
    "release:package:ios": "node scripts/workspace-app-command.mjs package --platform ios",
    "release:package:android": "node scripts/workspace-app-command.mjs package --platform android",
    "release:package:standalone": "node scripts/webserver-release.mjs package --deployment-profile standalone",
    "release:package:cloud": "node scripts/webserver-release.mjs package --deployment-profile cloud",
    "release:validate:standalone": "node scripts/webserver-release.mjs validate --deployment-profile standalone",
    "release:validate:cloud": "node scripts/webserver-release.mjs validate --deployment-profile cloud",
    "release:smoke:standalone": "node scripts/webserver-release-smoke.mjs --deployment-profile standalone",
    "release:smoke:cloud": "node scripts/webserver-release-smoke.mjs --deployment-profile cloud",
    "test": "cargo test --workspace && node --test tests/contract/agent-sync-state.contract.test.mjs tests/contract/backend-openapi-text.contract.test.mjs tests/contract/database-framework.contract.test.mjs tests/contract/database-recovery.contract.test.mjs tests/contract/deployment-profile-commands.contract.test.mjs tests/contract/dev-im-ingress.contract.test.mjs tests/contract/dev-runner.contract.test.mjs tests/contract/node-sync-manifest.contract.test.mjs tests/contract/postgres-ci.contract.test.mjs tests/contract/postgres-ha.contract.test.mjs tests/contract/release-archive.contract.test.mjs tests/contract/workspace-app-command.contract.test.mjs",
    "test:database:recovery": "node scripts/database-recovery-verify.mjs",
    "test:postgres:ha": "node scripts/postgres-ha-verify.mjs",
    "test:postgres:required": "node scripts/postgres-ci-verify.mjs",
    "check": "pnpm run check:app-composition && pnpm check:api-envelope && pnpm check:repository-docs && pnpm check:pnpm-script-standard && pnpm check:agent-workflow-standard && pnpm topology:validate && pnpm db:validate",
    "check:api-envelope": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "check:repository-docs": "node ../sdkwork-specs/tools/check-repository-docs-standard.mjs --root .",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --product-prefix web",
    "check:agent-workflow-standard": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
    "verify": "cargo fmt -- --check && cargo test --workspace && node --test tests/contract/agent-sync-state.contract.test.mjs tests/contract/backend-openapi-text.contract.test.mjs tests/contract/database-framework.contract.test.mjs tests/contract/database-recovery.contract.test.mjs tests/contract/deployment-profile-commands.contract.test.mjs tests/contract/dev-im-ingress.contract.test.mjs tests/contract/dev-runner.contract.test.mjs tests/contract/node-sync-manifest.contract.test.mjs tests/contract/postgres-ci.contract.test.mjs tests/contract/postgres-ha.contract.test.mjs tests/contract/release-archive.contract.test.mjs tests/contract/workspace-app-command.contract.test.mjs && pnpm api:materialize && cargo fmt -- --check && pnpm check && pnpm gateway:validate:cloud",
    "clean": "cargo clean",
    "api:materialize": "node tools/materialize_web_phase1_contracts.mjs && cargo fmt",
    "sdk:generate": "node sdks/sdkwork-web-app-sdk/bin/generate-sdk.mjs && node sdks/sdkwork-web-backend-sdk/bin/generate-sdk.mjs",
    "sdk:generate:app": "node sdks/sdkwork-web-app-sdk/bin/generate-sdk.mjs",
    "sdk:generate:backend": "node sdks/sdkwork-web-backend-sdk/bin/generate-sdk.mjs",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_web_baseline.sql --module-id web --owner web-platform --prefixes web_ --engines postgres,sqlite",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "db:postgres:plan": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode plan --config .env.postgres --app-root . --dry-run",
    "db:postgres:init": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode init --config .env.postgres --app-root .",
    "db:test:sqlite": "cargo test -p sdkwork-webserver-database-host --test sqlite_lifecycle",
    "db:test:postgres": "cargo test -p sdkwork-webserver-database-host --test postgres_lifecycle -- --ignored",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "gateway:package:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs bundle --root .",
    "gateway:validate:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs validate --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
