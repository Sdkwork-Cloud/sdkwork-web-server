{
  "schemaVersion": 3,
  "kind": "sdkwork.app",
  "app": {
    "key": "sdkwork-web",
    "name": "SDKWork Web Server",
    "displayName": "SDKWork Web Server",
    "description": "SDKWork standards-aligned HTTP web server control plane and immutable static-site/Wiki delivery data plane.",
    "vendor": "SDKWork",
    "officialWebsiteUrl": "https://sdkwork.com/apps/sdkwork-web",
    "supportUrl": "https://sdkwork.com/support",
    "privacyPolicyUrl": "https://sdkwork.com/privacy",
    "termsOfServiceUrl": "https://sdkwork.com/terms",
    "appType": "SDK",
    "identifiers": {
      "containerImage": "registry.sdkwork.com/apps/sdkwork-web"
    }
  },
  "backend": {
    "primaryLanguage": "rust",
    "framework": "axum",
    "appId": "sdkwork-web",
    "serviceId": "sdkwork-api-web-server-standalone-gateway",
    "profileKey": "backend-root-admin",
    "ownerMode": "tenant",
    "grantMode": "current",
    "accessTokenPermissionScope": [
      "web.sites.read",
      "web.sites.write",
      "web.certificates.read",
      "web.certificates.write",
      "web.nginx.write",
      "web.servers.read",
      "web.servers.write",
      "web.auditLogs.read"
    ]
  },
  "runtime": {
    "family": "server",
    "framework": "rust-service",
    "defaultPlatform": "API",
    "defaultArchitecture": "x64",
    "supportedDeploymentProfiles": [
      "standalone",
      "cloud"
    ],
    "defaultDeploymentProfile": "standalone"
  },
  "media": {
    "icons": {
      "primary": {
        "id": "sdkwork-web-primary-icon",
        "type": "ICON",
        "purpose": "PRIMARY",
        "platform": "API",
        "format": "PNG",
        "width": 1024,
        "height": 1024,
        "enabled": true,
        "resource": {
          "id": "sdkwork-web-primary-icon",
          "kind": "image",
          "source": "external_url",
          "url": "https://cdn.sdkwork.com/apps/sdkwork-web/assets/icon-1024.png",
          "mimeType": "image/png",
          "width": 1024,
          "height": 1024,
          "altText": "SDKWork Web Server"
        }
      },
      "platform": []
    },
    "screenshots": [],
    "previews": []
  },
  "publish": {
    "status": "BETA",
    "platforms": [
      "API"
    ],
    "installPlatforms": [
      "API"
    ],
    "installSkill": false,
    "storeUrl": "https://sdkwork.com/apps/sdkwork-web"
  },
  "artifacts": {
    "installConfig": {
      "defaultPackageId": "linux-x64-standalone-server-tar-gz",
      "packages": [
        {
          "id": "linux-x64-standalone-server-tar-gz",
          "name": "SDKWork Web Server Linux x64 Standalone",
          "sourceType": "SCRIPT",
          "packageFormat": "TAR_GZ",
          "platform": "API",
          "architecture": "x64",
          "profileBinding": "fixed",
          "deploymentProfile": "standalone",
          "runtimeTarget": "server",
          "targetPlatform": "linux",
          "enabled": false,
          "metadata": {
            "releaseBuildDeferred": true
          }
        },
        {
          "id": "linux-x64-cloud-server-tar-gz",
          "name": "SDKWork Web Server Linux x64 Cloud",
          "sourceType": "SCRIPT",
          "packageFormat": "TAR_GZ",
          "platform": "API",
          "architecture": "x64",
          "profileBinding": "fixed",
          "deploymentProfile": "cloud",
          "runtimeTarget": "server",
          "targetPlatform": "linux",
          "enabled": false,
          "metadata": {
            "releaseBuildDeferred": true
          }
        },
        {
          "id": "linux-arm64-standalone-server-tar-gz",
          "name": "SDKWork Web Server Linux arm64 Standalone",
          "sourceType": "SCRIPT",
          "packageFormat": "TAR_GZ",
          "platform": "API",
          "architecture": "arm64",
          "profileBinding": "fixed",
          "deploymentProfile": "standalone",
          "runtimeTarget": "server",
          "targetPlatform": "linux",
          "enabled": false,
          "metadata": {
            "releaseBuildDeferred": true
          }
        },
        {
          "id": "linux-arm64-cloud-server-tar-gz",
          "name": "SDKWork Web Server Linux arm64 Cloud",
          "sourceType": "SCRIPT",
          "packageFormat": "TAR_GZ",
          "platform": "API",
          "architecture": "arm64",
          "profileBinding": "fixed",
          "deploymentProfile": "cloud",
          "runtimeTarget": "server",
          "targetPlatform": "linux",
          "enabled": false,
          "metadata": {
            "releaseBuildDeferred": true
          }
        }
      ]
    }
  },
  "release": {
    "currentVersion": "0.1.0",
    "defaultChannel": "BETA",
    "latest": {
      "BETA": "0.1.0"
    },
    "notes": [
      {
        "version": "0.1.0",
        "channel": "BETA",
        "current": true,
        "summary": "Pre-release SDKWork standards alignment baseline; package builds remain deferred.",
        "packageIds": [
          "linux-x64-standalone-server-tar-gz",
          "linux-x64-cloud-server-tar-gz",
          "linux-arm64-standalone-server-tar-gz",
          "linux-arm64-cloud-server-tar-gz"
        ],
        "forceUpdate": false,
        "minSupportedVersion": "0.1.0"
      }
    ]
  },
  "security": {
    "checksumRequired": true,
    "signatureRequired": true,
    "sbomRequired": true
  },
  "metadata": {
    "deploymentConfig": "etc/sdkwork.deployment.config.json",
    "topologySpec": "specs/topology.spec.json",
    "componentSpec": "specs/component.spec.json",
    "workflowManifest": "sdkwork.workflow.json"
  }
}
