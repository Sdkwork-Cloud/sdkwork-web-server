{
  "name": "@sdkwork/web-app-sdk",
  "version": "0.1.0",
  "description": "SDKWork sdkwork-web-app-sdk composed consumer facade.",
  "type": "module",
  "private": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "pnpm run build:transport && pnpm run typecheck",
    "build:transport": "pnpm --dir generated/server-openapi build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sdkwork/sdk-common": "workspace:*"
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src",
    "generated/server-openapi/dist",
    "generated/server-openapi/src",
    "generated/server-openapi/sdkwork-sdk.json",
    "generated/server-openapi/README.md",
    "generated/server-openapi/LICENSE"
  ]
}
