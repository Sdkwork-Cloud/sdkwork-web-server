{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/web/sdkwork.tls-runtime.snapshot.schema.json",
  "title": "SDKWork TLS Runtime Assignment Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "snapshotUuid",
    "nodeUuid",
    "generation",
    "generatedAt",
    "compilerVersion",
    "snapshotSha256",
    "assignments",
    "limits"
  ],
  "properties": {
    "schemaVersion": {
      "const": "sdkwork.tls-runtime.v1"
    },
    "kind": {
      "const": "sdkwork.tls-runtime.snapshot"
    },
    "snapshotUuid": {
      "$ref": "#/$defs/opaqueId"
    },
    "nodeUuid": {
      "$ref": "#/$defs/opaqueId"
    },
    "generation": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "generatedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "compilerVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\s\\u0000-\\u001f\\u007f]+$"
    },
    "snapshotSha256": {
      "$ref": "#/$defs/sha256"
    },
    "assignments": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/assignment"
      }
    },
    "limits": {
      "$ref": "#/$defs/limits"
    }
  },
  "$defs": {
    "opaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "materialReference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*:[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assignmentUuid",
        "certificateUuid",
        "certificateVersion",
        "materialReference",
        "expectedFingerprintSha256",
        "serverNames",
        "notBefore",
        "notAfter",
        "policy"
      ],
      "properties": {
        "assignmentUuid": {
          "$ref": "#/$defs/opaqueId"
        },
        "certificateUuid": {
          "$ref": "#/$defs/opaqueId"
        },
        "certificateVersion": {
          "$ref": "#/$defs/opaqueId"
        },
        "materialReference": {
          "$ref": "#/$defs/materialReference"
        },
        "expectedFingerprintSha256": {
          "$ref": "#/$defs/sha256"
        },
        "serverNames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          }
        },
        "notBefore": {
          "$ref": "#/$defs/timestamp"
        },
        "notAfter": {
          "$ref": "#/$defs/timestamp"
        },
        "policy": {
          "$ref": "#/$defs/policy"
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumVersion", "maximumVersion", "alpn"],
      "properties": {
        "minimumVersion": {
          "enum": ["TLS1_2", "TLS1_3"]
        },
        "maximumVersion": {
          "enum": ["TLS1_2", "TLS1_3"]
        },
        "alpn": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["h2", "http/1.1"]
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximumAssignments", "maximumServerNamesPerAssignment"],
      "properties": {
        "maximumAssignments": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "maximumServerNamesPerAssignment": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    }
  }
}
