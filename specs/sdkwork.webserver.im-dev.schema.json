{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/web/sdkwork.webserver.im-dev.schema.json",
  "title": "SDKWork Web Server IM Development Ingress Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "application", "listener", "route", "deployment", "applications"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "kind": { "const": "sdkwork.webserver.im-dev" },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestPath", "deploymentConfigPath", "environment"],
      "properties": {
        "manifestPath": { "$ref": "#/$defs/path" },
        "deploymentConfigPath": { "$ref": "#/$defs/path" },
        "environment": {
          "enum": ["development", "test", "staging", "production"]
        }
      }
    },
    "listener": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bind"],
      "properties": {
        "bind": { "type": "string", "minLength": 1, "maxLength": 255 },
        "certificate": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "directory"],
              "properties": {
                "mode": { "const": "auto" },
                "directory": { "$ref": "#/$defs/path" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "certificateFile", "privateKeyFile"],
              "properties": {
                "mode": { "const": "files" },
                "certificateFile": { "$ref": "#/$defs/path" },
                "privateKeyFile": { "$ref": "#/$defs/path" }
              }
            }
          ]
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pathPrefix", "mobileUserAgentTokens"],
      "properties": {
        "pathPrefix": {
          "type": "string",
          "pattern": "^/.*$",
          "minLength": 1,
          "maxLength": 512
        },
        "mobileUserAgentTokens": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "applicationRoot", "serverScript", "gateway"],
      "properties": {
        "profile": { "enum": ["standalone", "cloud"] },
        "applicationRoot": { "$ref": "#/$defs/path" },
        "serverScript": { "type": "string", "minLength": 1, "maxLength": 128 },
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "required": ["host", "port", "httpPathPrefixes", "webSocketPathPrefixes"],
          "properties": {
            "host": { "type": "string", "minLength": 1, "maxLength": 255 },
            "port": { "$ref": "#/$defs/port" },
            "httpPathPrefixes": { "$ref": "#/$defs/pathPrefixes" },
            "webSocketPathPrefixes": { "$ref": "#/$defs/pathPrefixes" }
          }
        }
      }
    },
    "applications": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pc", "h5"],
      "properties": {
        "pc": { "$ref": "#/$defs/applicationTarget" },
        "h5": { "$ref": "#/$defs/applicationTarget" }
      }
    }
  },
  "$defs": {
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "pathPrefixes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^/", "minLength": 1, "maxLength": 512 }
    },
    "applicationTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "host", "port"],
      "properties": {
        "root": { "$ref": "#/$defs/path" },
        "host": { "type": "string", "minLength": 1, "maxLength": 255 },
        "port": { "$ref": "#/$defs/port" }
      }
    }
  }
}
