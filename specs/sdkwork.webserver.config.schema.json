{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/web/sdkwork.webserver.config.schema.json",
  "title": "SDKWork Web Server Application Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "appKey",
    "listeners",
    "resources",
    "virtualHosts"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "sdkwork.webserver.app"
    },
    "appKey": {
      "$ref": "#/$defs/id"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "limits": {
      "$ref": "#/$defs/limits"
    },
    "listeners": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/listener"
      }
    },
    "certificates": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/certificate"
      }
    },
    "tlsPolicies": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/tlsPolicy"
      }
    },
    "resolvers": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/resolver"
      }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20000,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/staticResource"
          },
          {
            "$ref": "#/$defs/proxyResource"
          },
          {
            "$ref": "#/$defs/redirectResource"
          },
          {
            "$ref": "#/$defs/respondResource"
          }
        ]
      }
    },
    "upstreams": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/upstream"
      }
    },
    "virtualHosts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/virtualHost"
      }
    },
    "observability": {
      "$ref": "#/$defs/observability"
    },
    "deployment": {
      "$ref": "#/$defs/deployment"
    },
    "metadata": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": {
        "pattern": "^[a-z][a-zA-Z0-9]{0,63}$"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "maxLength": 512
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nginxProfile": {
          "const": "http-core-v1"
        },
        "unknownDirectivePolicy": {
          "const": "error"
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxRequestBodyBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483648,
          "default": 10485760
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000
        },
        "drainTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 600000,
          "default": 30000
        },
        "maxConnections": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000,
          "default": 10000
        }
      }
    },
    "listener": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "bind", "port", "protocols"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "bind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "protocols": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["http1", "http2"]
          }
        },
        "tlsPolicyRef": {
          "$ref": "#/$defs/id"
        },
        "defaultVirtualHostRef": {
          "$ref": "#/$defs/id"
        },
        "maxConnections": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        }
      }
    },
    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "serverNames", "source"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "serverNames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/serverName"
          }
        },
        "source": {
          "$ref": "#/$defs/protectedFileCertificateSource"
        }
      }
    },
    "protectedFileCertificateSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "certificateFile", "privateKeyFile"],
      "properties": {
        "type": {
          "const": "protected-file"
        },
        "certificateFile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "privateKeyFile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "tlsPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "certificateRef"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "certificateRef": {
          "$ref": "#/$defs/id"
        },
        "minimumVersion": {
          "enum": ["tls1.2", "tls1.3"],
          "default": "tls1.2"
        },
        "maximumVersion": {
          "enum": ["tls1.2", "tls1.3"],
          "default": "tls1.3"
        },
        "alpn": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["h2", "http/1.1"]
          },
          "default": ["h2", "http/1.1"]
        }
      }
    },
    "resolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "servers": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 30000,
          "default": 2000
        },
        "maximumAnswers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64,
          "default": 16
        }
      }
    },
    "staticResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "root"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "static"
        },
        "root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "indexFiles": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "default": ["index.html"]
        },
        "spaFallback": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "followSymlinks": {
          "const": false,
          "default": false
        }
      }
    },
    "proxyResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "upstreamRef"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "proxy"
        },
        "upstreamRef": {
          "$ref": "#/$defs/id"
        },
        "stripPrefix": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "redirectResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "status", "location"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "redirect"
        },
        "status": {
          "enum": [301, 302, 307, 308]
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "respondResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "status"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "respond"
        },
        "status": {
          "type": "integer",
          "minimum": 200,
          "maximum": 599
        },
        "contentType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "default": "text/plain; charset=utf-8"
        },
        "body": {
          "type": "string",
          "maxLength": 65536,
          "default": ""
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targets"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/upstreamTarget"
          }
        },
        "connectTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000,
          "default": 5000
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000
        },
        "maxIdleConnections": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100000,
          "default": 128
        }
      }
    },
    "upstreamTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 1
        }
      }
    },
    "virtualHost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "listenerRefs", "serverNames", "routes"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "listenerRefs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "serverNames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/serverName"
          }
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10000,
          "items": {
            "$ref": "#/$defs/route"
          }
        }
      }
    },
    "serverName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^(?:\\*\\.)?[A-Za-z0-9](?:[A-Za-z0-9.-]{0,251}[A-Za-z0-9])?\\.?$"
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "resourceRef"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "match": {
          "$ref": "#/$defs/routeMatch"
        },
        "resourceRef": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "routeMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pathType", "path"],
      "properties": {
        "pathType": {
          "enum": ["exact", "prefix"]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8192,
          "pattern": "^/"
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z!#$%&'*+.^_`|~-]{1,32}$"
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accessLog": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "drainTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 600000
        }
      }
    }
  }
}
