{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/web/sdkwork.webserver.config.schema.json",
  "title": "SDKWork Web Server Application Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "appKey",
    "listeners",
    "resources",
    "virtualHosts"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "sdkwork.webserver.app"
    },
    "appKey": {
      "$ref": "#/$defs/id"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "limits": {
      "$ref": "#/$defs/limits"
    },
    "listeners": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/listener"
      }
    },
    "certificates": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/certificate"
      }
    },
    "tlsPolicies": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/tlsPolicy"
      }
    },
    "resolvers": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/resolver"
      }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20000,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/staticResource"
          },
          {
            "$ref": "#/$defs/proxyResource"
          },
          {
            "$ref": "#/$defs/redirectResource"
          },
          {
            "$ref": "#/$defs/respondResource"
          }
        ]
      }
    },
    "upstreams": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/upstream"
      }
    },
    "virtualHosts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/virtualHost"
      }
    },
    "observability": {
      "$ref": "#/$defs/observability"
    },
    "deployment": {
      "$ref": "#/$defs/deployment"
    },
    "metadata": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": {
        "pattern": "^[a-z][a-zA-Z0-9]{0,63}$"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "maxLength": 512
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nginxProfile": {
          "const": "http-core-v1"
        },
        "unknownDirectivePolicy": {
          "const": "error"
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxRequestBodyBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483648,
          "default": 10485760
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000
        },
        "requestBodyStartTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000,
          "description": "Maximum wait for the first meaningful request Body Frame after request dispatch begins."
        },
        "requestBodyIdleTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000,
          "description": "Maximum idle gap between meaningful request Body Frames after Body progress begins."
        },
        "responseBodyIdleTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000,
          "description": "Maximum idle gap between response Body Frames after response processing begins."
        },
        "connectionWriteTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000,
          "description": "Maximum continuous Pending duration for downstream write, flush, or shutdown operations."
        },
        "http1KeepAliveIdleTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 75000,
          "description": "Maximum HTTP/1 idle wait for a subsequent request after the prior response lifecycle and pending writes complete."
        },
        "http1MaxPipelineDepth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 16,
          "description": "Maximum number of fully read HTTP/1 request heads awaiting service dispatch on one connection. Excess depth closes the connection without buffering request bodies."
        },
        "drainTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 600000,
          "default": 30000
        },
        "maxConnections": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000,
          "default": 10000
        },
        "maxConcurrentRequests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "default": 4096,
          "description": "Process-wide admitted request limit across all listeners. Saturation is rejected without queueing, and permits remain held through response Body completion."
        },
        "maxConcurrentHealthChecks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 64,
          "description": "Process-wide active upstream health probe task ceiling for one immutable runtime generation."
        },
        "maxRequestHeaderBytes": {
          "type": "integer",
          "minimum": 8192,
          "maximum": 1048576,
          "default": 65536
        },
        "maxRequestLineBytes": {
          "type": "integer",
          "minimum": 16,
          "maximum": 65536,
          "default": 8192
        },
        "maxRequestMethodBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256,
          "default": 32
        },
        "maxRequestTargetBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65536,
          "default": 8192
        },
        "maxUriPathBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65536,
          "default": 8192,
          "description": "Maximum raw URI Path bytes for every HTTP version."
        },
        "maxDecodedPathBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65536,
          "default": 8192,
          "description": "Maximum Path bytes after one validated percent-decoding pass without changing routing representation."
        },
        "maxPathSegments": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096,
          "default": 256
        },
        "maxQueryStringBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65536,
          "default": 4096
        },
        "maxQueryParameters": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4096,
          "default": 256
        },
        "maxQueryComponentBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65536,
          "default": 1024,
          "description": "Maximum raw bytes for each query parameter name or value component."
        },
        "maxHeaderNameBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8192,
          "default": 256
        },
        "maxHeaderValueBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576,
          "default": 8192
        },
        "maxRequestHeaders": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 100
        },
        "requestHeaderTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000,
          "default": 10000
        },
        "maxChunkLineBytes": {
          "type": "integer",
          "minimum": 16,
          "maximum": 8192,
          "default": 1024
        },
        "maxTrailerBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1048576,
          "default": 8192,
          "description": "Maximum encoded bytes for request or response Trailer declarations and actual Trailer fields. Zero disables Trailers together with maxTrailers."
        },
        "maxTrailers": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1024,
          "default": 32,
          "description": "Maximum request or response Trailer field count for declarations and actual Trailer frames. Zero disables Trailers together with maxTrailerBytes."
        },
        "http2MaxConcurrentStreams": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "default": 100
        },
        "maxConnectionAgeMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 86400000,
          "default": 3600000,
          "description": "Maximum total lifetime of an accepted HTTP/1 or HTTP/2 connection before protocol-aware graceful retirement. In-flight work may drain only through drainTimeoutMs."
        },
        "http2KeepAliveIntervalMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 3600000,
          "default": 60000,
          "description": "Maximum inbound HTTP/2 Frame inactivity before Hyper sends a Keep-Alive PING, including when no streams are active."
        },
        "http2KeepAliveTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000,
          "default": 20000,
          "description": "Maximum wait for the corresponding HTTP/2 PING ACK before Hyper sends GOAWAY(NO_ERROR) and closes the connection."
        },
        "http2MaxPendingAcceptResetStreams": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 20
        },
        "http2MaxLocalErrorResetStreams": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096,
          "default": 128
        },
        "http2MaxSendBufferBytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 16777216,
          "default": 65536
        },
        "http2MaxHeaderListBytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 1048576,
          "default": 65536
        },
        "http2MaxFrameBytes": {
          "type": "integer",
          "minimum": 16384,
          "maximum": 16777215,
          "default": 16384
        },
        "http2AbuseWindowMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000,
          "default": 1000
        },
        "http2MaxFramesPerWindow": {
          "type": "integer",
          "minimum": 100,
          "maximum": 1000000,
          "default": 10000
        },
        "http2MaxNewStreamsPerWindow": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "default": 1000
        },
        "http2MaxResetFramesPerWindow": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "default": 100
        },
        "http2MaxContinuationFrames": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1024,
          "default": 16
        },
        "http2MaxEncodedHeaderBlockBytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 1048576,
          "default": 65536
        }
      }
    },
    "listener": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "bind", "port", "protocols"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "bind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "protocols": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["http1", "http2"]
          }
        },
        "tlsPolicyRef": {
          "$ref": "#/$defs/id"
        },
        "tlsRuntime": {
          "enum": ["assignment"]
        },
        "defaultVirtualHostRef": {
          "$ref": "#/$defs/id"
        },
        "maxConnections": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "trustedProxy": {
          "$ref": "#/$defs/trustedProxy"
        },
        "proxyProtocol": {
          "$ref": "#/$defs/proxyProtocol"
        }
      }
    },
    "trustedProxy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trustedCidrs"],
      "properties": {
        "trustedCidrs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 64
          },
          "description": "Immediate TCP peer networks authorized to supply the configured real-IP Header and one X-Forwarded-Proto request scheme. Omission of trustedProxy trusts no forwarding Header. Semantic validation rejects overbroad networks."
        },
        "header": {
          "type": "string",
          "enum": ["x-forwarded-for"],
          "default": "x-forwarded-for"
        },
        "recursive": {
          "type": "boolean",
          "default": false,
          "description": "When true, scan right-to-left through trusted proxy hops and select the first non-trusted address; an all-trusted chain resolves to its leftmost address."
        },
        "maxHops": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64,
          "default": 16
        },
        "maxHeaderBytes": {
          "type": "integer",
          "minimum": 64,
          "maximum": 65536,
          "default": 4096
        }
      }
    },
    "proxyProtocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trustedSourceCidrs"],
      "properties": {
        "trustedSourceCidrs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 3, "maxLength": 64},
          "description": "Immediate TCP peer networks authorized to send a mandatory PROXY protocol header."
        },
        "versions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"enum": ["v1", "v2"]},
          "default": ["v1", "v2"]
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 10000,
          "default": 3000
        },
        "maxHeaderBytes": {
          "type": "integer",
          "minimum": 107,
          "maximum": 4096,
          "default": 536
        },
        "crc32cPolicy": {
          "type": "string",
          "enum": ["ignore", "validate-if-present", "required"],
          "default": "ignore",
          "description": "PROXY v2 CRC32C handling. validate-if-present and required need v2 in versions; CRC is integrity detection, not peer authentication."
        }
      }
    },
    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "serverNames", "source"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "serverNames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/serverName"
          }
        },
        "source": {
          "$ref": "#/$defs/protectedFileCertificateSource"
        }
      }
    },
    "protectedFileCertificateSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "certificateFile", "privateKeyFile"],
      "properties": {
        "type": {
          "const": "protected-file"
        },
        "certificateFile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "privateKeyFile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "tlsPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "oneOf": [
        {
          "required": ["certificateRef"],
          "not": {
            "required": ["certificateRefs"]
          }
        },
        {
          "required": ["certificateRefs"],
          "not": {
            "required": ["certificateRef"]
          }
        }
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "certificateRef": {
          "$ref": "#/$defs/id"
        },
        "certificateRefs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "minimumVersion": {
          "enum": ["tls1.2", "tls1.3"],
          "default": "tls1.2"
        },
        "maximumVersion": {
          "enum": ["tls1.2", "tls1.3"],
          "default": "tls1.3"
        },
        "alpn": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["h2", "http/1.1"]
          },
          "default": ["h2", "http/1.1"]
        }
      }
    },
    "resolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "servers": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 30000,
          "default": 2000
        },
        "maximumAnswers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64,
          "default": 16
        },
        "maxConcurrentQueries": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 64,
          "description": "Maximum in-flight system DNS lookups for this resolver profile. Saturation fails without queueing."
        }
      }
    },
    "staticResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "root"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "static"
        },
        "root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "indexFiles": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "default": ["index.html"]
        },
        "spaFallback": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "followSymlinks": {
          "const": false,
          "default": false
        }
      }
    },
    "proxyResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "upstreamRef"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "proxy"
        },
        "upstreamRef": {
          "$ref": "#/$defs/id"
        },
        "stripPrefix": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "redirectResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "status", "location"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "redirect"
        },
        "status": {
          "enum": [301, 302, 307, 308]
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      }
    },
    "respondResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "status"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "respond"
        },
        "status": {
          "type": "integer",
          "minimum": 200,
          "maximum": 599
        },
        "contentType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "default": "text/plain; charset=utf-8"
        },
        "body": {
          "type": "string",
          "maxLength": 65536,
          "default": ""
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targets"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/upstreamTarget"
          }
        },
        "loadBalancing": {
          "type": "string",
          "enum": ["round-robin", "least-connections", "random-two-least-connections", "ip-hash"],
          "default": "round-robin",
          "description": "Business-request selection strategy. Least-connections minimizes active request or HTTP/2 Stream load divided by target weight. Random-two-least-connections samples two distinct eligible targets by effective weight and compares the same weighted load. Ip-hash uses the listener-resolved effective client IP, which defaults to the direct peer, and cannot be combined with target slowStartMs."
        },
        "resolverRef": {
          "$ref": "#/$defs/id"
        },
        "addressPolicy": {
          "$ref": "#/$defs/upstreamAddressPolicy"
        },
        "tls": {
          "$ref": "#/$defs/upstreamTlsPolicy"
        },
        "connectTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000,
          "default": 5000
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000
        },
        "maxIdleConnections": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100000,
          "default": 128
        },
        "maxConnections": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "default": 256,
          "description": "Aggregate process-local hard ceiling for connecting, active, HTTP/2-multiplexed, and idle physical connections owned by one immutable upstream generation."
        },
        "maxResponseHeaderBytes": {
          "type": "integer",
          "minimum": 8192,
          "maximum": 1048576,
          "default": 65536,
          "description": "Maximum decoded upstream response Header bytes, counted across every field occurrence before proxy forwarding."
        },
        "maxResponseHeaders": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 100,
          "description": "Maximum number of decoded upstream response Header field occurrences before proxy forwarding."
        },
        "idleConnectionTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000,
          "description": "Maximum idle lifetime of a pooled upstream connection before it is removed and the next connection resolves again."
        },
        "maxInFlightRequests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "default": 1024,
          "description": "Non-queuing per-upstream admitted request limit held through streaming response completion or cancellation."
        },
        "retry": {
          "$ref": "#/$defs/upstreamRetry"
        },
        "passiveHealth": {
          "$ref": "#/$defs/upstreamPassiveHealth"
        },
        "activeHealth": {
          "$ref": "#/$defs/upstreamActiveHealth"
        }
      }
    },
    "upstreamAddressPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowedCidrs": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 64
          },
          "default": [],
          "description": "Explicit narrow authorization for loopback, RFC1918, RFC6598, IPv4 link-local, IPv6 ULA, or IPv6 link-local upstream destinations. Public and hard-forbidden ranges cannot be listed."
        }
      }
    },
    "upstreamTlsPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trustMode": {
          "enum": ["system", "custom", "system-and-custom"],
          "default": "system"
        },
        "caCertificateFiles": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "default": []
        },
        "clientCertificateFile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "clientPrivateKeyFile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "minimumVersion": {
          "enum": ["tls1.2", "tls1.3"],
          "default": "tls1.2"
        },
        "maximumVersion": {
          "enum": ["tls1.2", "tls1.3"],
          "default": "tls1.3"
        }
      }
    },
    "upstreamPassiveHealth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "failureThreshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 3
        },
        "ejectionTimeMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 600000,
          "default": 30000
        },
        "failureStatuses": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 500,
            "maximum": 599
          },
          "default": [502, 503, 504]
        }
      }
    },
    "upstreamRetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 2,
          "maximum": 8,
          "default": 2,
          "description": "Total sequential upstream attempts, including the first attempt."
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "default": 30000,
          "description": "Total wall-clock budget shared by all attempts."
        },
        "retryOn": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": ["error", "timeout", "http_502", "http_503", "http_504"]
          },
          "default": ["error", "timeout"]
        }
      }
    },
    "upstreamActiveHealth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "enum": ["GET", "HEAD"],
          "default": "GET"
        },
        "uri": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "pattern": "^/",
          "default": "/"
        },
        "intervalMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 600000,
          "default": 10000
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000,
          "default": 2000
        },
        "unhealthyThreshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 3
        },
        "healthyThreshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 2
        },
        "successStatusMin": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "default": 200
        },
        "successStatusMax": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "default": 399
        },
        "maxResponseBodyBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1048576,
          "default": 65536
        }
      }
    },
    "upstreamTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 1,
          "description": "Relative business-traffic selection slots among targets that currently pass active and passive health."
        },
        "backup": {
          "type": "boolean",
          "default": false,
          "description": "Reserve this target for selection only when no unattempted primary target is currently eligible."
        },
        "slowStartMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 3600000,
          "description": "Optional monotonic interval for recovering effective selection weight from one integer slot to nominal after active or passive unavailability."
        },
        "maxConnections": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000,
          "description": "Optional physical connection ceiling for this unique target authority, including connecting, TLS, active HTTP/1, multiplexed HTTP/2, and idle sockets."
        }
      }
    },
    "virtualHost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "listenerRefs", "serverNames", "routes"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "listenerRefs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "serverNames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/serverName"
          }
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10000,
          "items": {
            "$ref": "#/$defs/route"
          }
        }
      }
    },
    "serverName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^(?:\\*\\.)?[A-Za-z0-9](?:[A-Za-z0-9.-]{0,251}[A-Za-z0-9])?\\.?$"
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match", "resourceRef"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "match": {
          "$ref": "#/$defs/routeMatch"
        },
        "resourceRef": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "routeMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pathType", "path"],
      "properties": {
        "pathType": {
          "enum": ["exact", "prefix"]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8192,
          "pattern": "^/"
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z!#$%&'*+.^_`|~-]{1,32}$"
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accessLog": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "drainTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 600000
        },
        "reload": {
          "$ref": "#/$defs/reload"
        },
        "resourcePressure": {
          "$ref": "#/$defs/resourcePressure"
        }
      }
    },
    "resourcePressure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sampleIntervalMs": {
          "type": "integer",
          "minimum": 50,
          "maximum": 10000,
          "default": 250
        },
        "maximumProcessMemoryBytes": {
          "type": "integer",
          "minimum": 134217728,
          "maximum": 17592186044416,
          "default": 1073741824
        },
        "memoryReserveBytes": {
          "type": "integer",
          "minimum": 16777216,
          "maximum": 68719476736,
          "default": 67108864
        },
        "memoryAdmissionPercent": {
          "type": "integer",
          "minimum": 50,
          "maximum": 99,
          "default": 90
        },
        "memoryRecoveryPercent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 98,
          "default": 80
        },
        "maximumOpenHandles": {
          "type": "integer",
          "minimum": 64,
          "maximum": 1048576,
          "default": 16384
        },
        "openHandleReserve": {
          "type": "integer",
          "minimum": 8,
          "maximum": 65536,
          "default": 128
        },
        "openHandleAdmissionPercent": {
          "type": "integer",
          "minimum": 50,
          "maximum": 99,
          "default": 90
        },
        "openHandleRecoveryPercent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 98,
          "default": 80
        },
        "eventLoopLagAdmissionMs": {
          "type": "integer",
          "minimum": 10,
          "maximum": 10000,
          "default": 250
        },
        "eventLoopLagRecoveryMs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9999,
          "default": 50
        },
        "consecutivePressureSamples": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 2
        },
        "consecutiveRecoverySamples": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 4
        },
        "operationsReserveRequests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 16
        },
        "sampleFailurePolicy": {
          "enum": ["fail-open", "fail-closed"],
          "default": "fail-closed"
        }
      }
    },
    "reload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["disabled", "watch"],
          "default": "disabled"
        },
        "pollIntervalMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000,
          "default": 1000
        }
      }
    }
  }
}
