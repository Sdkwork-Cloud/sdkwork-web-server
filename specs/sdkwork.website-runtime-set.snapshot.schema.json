{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/web/sdkwork.website-runtime-set.snapshot.schema.json",
  "title": "SDKWork Website Runtime Set Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "snapshotUuid",
    "nodeUuid",
    "environment",
    "generation",
    "generatedAt",
    "compilerVersion",
    "snapshotSha256",
    "maximumSites",
    "descriptors"
  ],
  "properties": {
    "schemaVersion": {
      "const": "sdkwork.website-runtime-set.v1"
    },
    "kind": {
      "const": "sdkwork.website-runtime-set.snapshot"
    },
    "snapshotUuid": {
      "$ref": "#/$defs/opaqueId"
    },
    "nodeUuid": {
      "$ref": "#/$defs/opaqueId"
    },
    "environment": {
      "enum": ["development", "test", "staging", "production"]
    },
    "generation": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "generatedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "compilerVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\s\\u0000-\\u001f\\u007f]+$"
    },
    "snapshotSha256": {
      "$ref": "#/$defs/sha256"
    },
    "maximumSites": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10000
    },
    "descriptors": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object"
      }
    }
  },
  "$defs": {
    "opaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    }
  }
}
