{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-web-server",
  "archetype": "application-http-gateway",
  "profileRoot": "etc/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "gatewayBind": "127.0.0.1:3800",
    "desktopBuildProfileId": "standalone.production"
  },
  "profileFiles": {
    "cloud.development": "etc/topology/cloud.development.env",
    "cloud.production": "etc/topology/cloud.production.env",
    "standalone.development": "etc/topology/standalone.development.env",
    "standalone.production": "etc/topology/standalone.production.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_WEB_DEPLOYMENT_PROFILE",
    "environment": "SDKWORK_WEB_ENVIRONMENT",
    "profileId": "SDKWORK_WEB_PROFILE_ID",
    "standaloneGatewayBind": "SDKWORK_WEB_APPLICATION_PUBLIC_INGRESS_BIND",
    "apiGatewayBaseUrl": "SDKWORK_WEB_PLATFORM_API_GATEWAY_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_WEB_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_WEB_APPLICATION_PUBLIC_HTTP_URL"
    },
    "application.app-http": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_WEB_APPLICATION_APP_HTTP_BIND",
      "httpUrlEnv": "SDKWORK_WEB_APPLICATION_APP_HTTP_URL"
    },
    "application.backend-http": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_WEB_APPLICATION_BACKEND_HTTP_BIND",
      "httpUrlEnv": "SDKWORK_WEB_APPLICATION_BACKEND_HTTP_URL"
    },
    "edge.website-delivery": {
      "connectivityPlane": "edge",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_WEB_WEBSITE_DELIVERY_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_WEB_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_WEB_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "web.sdkwork.com"
    },
    "application.app-http": {
      "httpHost": "web-app.sdkwork.com"
    },
    "application.backend-http": {
      "httpHost": "web-admin.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_WEB"
  },
  "components": {
    "appApiRouter": {
      "crate": "sdkwork-api-web-server-standalone-gateway",
      "binary": "sdkwork-api-web-server-standalone-gateway"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-api-web-server-standalone-gateway",
            "binary": "sdkwork-api-web-server-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.development": {
        "processes": [
          {
            "id": "application.node-daemon",
            "crate": "sdkwork-web-agent",
            "binary": "sdkwork-web-node-daemon",
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "cloud.production": {
        "processes": [
          {
            "id": "edge.website-delivery",
            "crate": "sdkwork-web-server-website-delivery-edge-runtime",
            "binary": "sdkwork-web-server-website-delivery-edge-runtime",
            "required": true,
            "role": "edge-runtime",
            "script": "_sdkwork:runtime:website-data-plane",
            "decisionRef": "docs/architecture/decisions/ADR-20260721-compiled-website-runtime-descriptor.md"
          }
        ],
        "healthSurfaces": [
          "edge.website-delivery",
          "platform.api-gateway"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-api-web-server-standalone-gateway",
            "binary": "sdkwork-api-web-server-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      }
    }
  },
  "packaging": {
    "cloudConfigFiles": [],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-web-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  }
}
