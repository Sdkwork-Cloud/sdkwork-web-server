# Web Node Daemon environment.

# Control plane base URL (no trailing slash)
SDKWORK_WEB_CONTROL_PLANE_URL=http://127.0.0.1:3800

# Node bootstrap credential from POST /backend/v3/api/servers.
# The v3 response field remains agentToken until the reviewed v4 API migration.
SDKWORK_WEB_NODE_TOKEN=

# Sync interval in seconds
SDKWORK_WEB_NODE_SYNC_INTERVAL_SECS=30

# Durable desired/observed generation state.
# The default filename remains sdkwork-web-agent-state.json during compatibility rollout.
# SDKWORK_WEB_NODE_STATE_PATH=/var/lib/sdkwork/web/edge/sdkwork-web-agent-state.json
# SDKWORK_WEB_NODE_STATE_DIR=/var/lib/sdkwork/web/edge
# SDKWORK_WEB_EDGE_ROOT=/var/lib/sdkwork/web/edge

# Deprecated aliases: SDKWORK_WEB_AGENT_TOKEN, SDKWORK_WEB_AGENT_SYNC_INTERVAL_SECS,
# SDKWORK_WEB_AGENT_STATE_PATH, SDKWORK_WEB_AGENT_STATE_DIR. Do not set a preferred
# key and its legacy alias to different values; the daemon fails closed on conflict.

# Local nginx + certificate paths (see sdkwork-webserver-edge-runtime)
SDKWORK_WEB_NGINX_ENABLED=true
SDKWORK_WEB_NGINX_SITES_ROOT=/etc/nginx/sites-enabled/sdkwork
SDKWORK_WEB_CERT_LIVE_ROOT=/opt/certs/letsencrypt/live
