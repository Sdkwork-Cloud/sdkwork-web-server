{
  "$schema": "../specs/sdkwork.webserver.im-dev.schema.json",
  "schemaVersion": 2,
  "kind": "sdkwork.webserver.im-dev",
  "application": {
    "manifestPath": "../../sdkwork-im/sdkwork.app.config.json",
    "deploymentConfigPath": "../../sdkwork-im/etc/sdkwork.deployment.config.json",
    "environment": "development"
  },
  "listener": {
    "bind": "0.0.0.0"
  },
  "route": {
    "pathPrefix": "/",
    "mobileUserAgentTokens": [
      "Android",
      "webOS",
      "iPhone",
      "iPad",
      "iPod",
      "BlackBerry",
      "IEMobile",
      "Opera Mini",
      "Mobile"
    ]
  },
  "deployment": {
    "profile": "standalone",
    "applicationRoot": "../../sdkwork-im",
    "serverScript": "dev:server",
    "gateway": {
      "host": "127.0.0.1",
      "port": 18079,
      "httpPathPrefixes": [
        "/im/v3/api",
        "/app/v3/api",
        "/backend/v3/api",
        "/agent/v3/api",
        "/openapi.json",
        "/openapi/",
        "/health",
        "/healthz",
        "/livez",
        "/ready",
        "/readyz",
        "/metrics"
      ],
      "webSocketPathPrefixes": [
        "/im/v3/api/realtime/ws"
      ]
    }
  },
  "applications": {
    "pc": {
      "root": "../../sdkwork-im/apps/sdkwork-im-pc",
      "host": "127.0.0.1",
      "port": 4176
    },
    "h5": {
      "root": "../../sdkwork-im/apps/sdkwork-im-h5",
      "host": "127.0.0.1",
      "port": 4177
    }
  }
}
