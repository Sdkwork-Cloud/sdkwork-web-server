# Cloud website/Wiki data-plane profile fragment.
# Deployment must inject non-empty node UUID and tenant scope hash values.
SDKWORK_WEB_ENVIRONMENT=production
SDKWORK_WEB_DEPLOYMENT_PROFILE=cloud
SDKWORK_WEB_RUNTIME_TARGET=server
SDKWORK_WEB_SERVER_CONFIG_FILE=/etc/sdkwork/web/sdkwork.webserver.config.json
SDKWORK_WEB_RUNTIME_ASSIGNMENT_SOURCE=cloud
SDKWORK_WEB_INTERNAL_API_BASE_URL=https://web.sdkwork.com
SDKWORK_WEB_NODE_TOKEN_FILE=/run/secrets/sdkwork-web-node-token
SDKWORK_WEB_NODE_UUID=
SDKWORK_WEB_WEBSITE_RUNTIME_ENVIRONMENT=production
SDKWORK_WEB_NODE_VERSION=0.1.0
SDKWORK_WEB_WEBSITE_RUNTIME_SET_RECOVERY_DIRECTORY=/var/lib/sdkwork/web/website-runtime-recovery
SDKWORK_WEB_WEBSITE_RUNTIME_SET_POLL_INTERVAL_MS=2000
SDKWORK_WEB_TLS_RUNTIME_SOURCE=external
SDKWORK_WEB_WEBSITE_TENANT_SCOPE_HASH=
SDKWORK_WEB_WEBSITE_PROVIDER_VALIDATION_CONCURRENCY=16
SDKWORK_WEB_WEBSITE_PROVIDER_BUFFERED_CONTENT_BYTES=268435456
SDKWORK_WEB_WEBSITE_PROVIDER_EVENT_CONFIG_FILE=/etc/sdkwork/web/website-provider-events.json
SDKWORK_WEBSERVER_DRIVE_INTERNAL_API_BASE_URL=https://drive-internal.sdkwork.com
SDKWORK_WEBSERVER_DRIVE_INTERNAL_API_INGRESS_TOKEN_FILE=/run/secrets/sdkwork-drive-ingress-token
SDKWORK_WEBSERVER_KNOWLEDGEBASE_INTERNAL_API_BASE_URL=https://knowledgebase.sdkwork.com
SDKWORK_WEBSERVER_KNOWLEDGEBASE_INTERNAL_API_INGRESS_TOKEN_FILE=/run/secrets/sdkwork-knowledgebase-ingress-token
SDKWORK_WEB_DATA_PLANE_OPERATIONS_BIND=127.0.0.1:3901
