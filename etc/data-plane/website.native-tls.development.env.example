SDKWORK_WEB_ENVIRONMENT=development
SDKWORK_WEB_DEPLOYMENT_PROFILE=standalone
SDKWORK_WEB_RUNTIME_TARGET=server
SDKWORK_WEB_SERVER_CONFIG_FILE=etc/data-plane/website.native-tls.config.json
SDKWORK_WEB_RUNTIME_ASSIGNMENT_SOURCE=file
SDKWORK_WEB_WEBSITE_RUNTIME_SET_FILE=.sdkwork/runtime/website-runtime-set.json
SDKWORK_WEB_WEBSITE_RUNTIME_SET_RECOVERY_DIRECTORY=.sdkwork/runtime/website-runtime-recovery
SDKWORK_WEB_WEBSITE_RUNTIME_SET_POLL_INTERVAL_MS=2000
SDKWORK_WEB_WEBSITE_TENANT_SCOPE_HASH=1111111111111111111111111111111111111111111111111111111111111111
SDKWORK_WEB_WEBSITE_PROVIDER_VALIDATION_CONCURRENCY=16
SDKWORK_WEB_WEBSITE_PROVIDER_BUFFERED_CONTENT_BYTES=268435456
SDKWORK_WEB_TLS_RUNTIME_SOURCE=file
SDKWORK_WEB_TLS_RUNTIME_SNAPSHOT_FILE=.sdkwork/runtime/tls-runtime.json
SDKWORK_WEB_TLS_MATERIAL_ROOT=.sdkwork/secrets/tls-materials
SDKWORK_WEB_TLS_LISTENER_ID=website-https
SDKWORK_WEB_TLS_RUNTIME_POLL_INTERVAL_MS=2000
SDKWORK_WEB_TLS_RUNTIME_RECOVERY_DIRECTORY=.sdkwork/runtime/tls-runtime-recovery
SDKWORK_WEB_DATA_PLANE_OPERATIONS_BIND=127.0.0.1:3901
