{
  "schemaVersion": 1,
  "kind": "sdkwork.webserver.app",
  "appKey": "sdkwork-example-web",
  "compatibility": {
    "nginxProfile": "http-core-v1",
    "unknownDirectivePolicy": "error"
  },
  "limits": {
    "maxRequestBodyBytes": 10485760,
    "requestTimeoutMs": 30000,
    "requestBodyStartTimeoutMs": 30000,
    "requestBodyIdleTimeoutMs": 30000,
    "responseBodyIdleTimeoutMs": 30000,
    "connectionWriteTimeoutMs": 30000,
    "http1KeepAliveIdleTimeoutMs": 75000,
    "http1MaxPipelineDepth": 16,
    "drainTimeoutMs": 30000,
    "maxConnections": 10000,
    "maxConcurrentRequests": 4096,
    "maxConcurrentHealthChecks": 64,
    "maxRequestHeaderBytes": 65536,
    "maxRequestLineBytes": 8192,
    "maxRequestMethodBytes": 32,
    "maxRequestTargetBytes": 8192,
    "maxUriPathBytes": 8192,
    "maxDecodedPathBytes": 8192,
    "maxPathSegments": 256,
    "maxQueryStringBytes": 4096,
    "maxQueryParameters": 256,
    "maxQueryComponentBytes": 1024,
    "maxHeaderNameBytes": 256,
    "maxHeaderValueBytes": 8192,
    "maxRequestHeaders": 100,
    "requestHeaderTimeoutMs": 10000,
    "maxChunkLineBytes": 1024,
    "maxTrailerBytes": 8192,
    "maxTrailers": 32,
    "http2MaxConcurrentStreams": 100,
    "maxConnectionAgeMs": 3600000,
    "http2KeepAliveIntervalMs": 60000,
    "http2KeepAliveTimeoutMs": 20000,
    "http2MaxPendingAcceptResetStreams": 20,
    "http2MaxLocalErrorResetStreams": 128,
    "http2MaxSendBufferBytes": 65536,
    "http2MaxHeaderListBytes": 65536,
    "http2MaxFrameBytes": 16384,
    "http2AbuseWindowMs": 1000,
    "http2MaxFramesPerWindow": 10000,
    "http2MaxNewStreamsPerWindow": 1000,
    "http2MaxResetFramesPerWindow": 100,
    "http2MaxContinuationFrames": 16,
    "http2MaxEncodedHeaderBlockBytes": 65536
  },
  "listeners": [
    {
      "id": "public-http",
      "bind": "127.0.0.1",
      "port": 8080,
      "protocols": ["http1"],
      "defaultVirtualHostRef": "example-web"
    }
  ],
  "certificates": [],
  "tlsPolicies": [],
  "resolvers": [],
  "resources": [
    {
      "id": "health-response",
      "type": "respond",
      "status": 200,
      "contentType": "text/plain; charset=utf-8",
      "body": "ok\n"
    },
    {
      "id": "web-static",
      "type": "static",
      "root": "public",
      "indexFiles": ["index.html"],
      "spaFallback": "index.html",
      "followSymlinks": false
    },
    {
      "id": "example-origin-proxy",
      "type": "proxy",
      "upstreamRef": "example-origin",
      "stripPrefix": true
    }
  ],
  "upstreams": [
    {
      "id": "example-origin",
      "loadBalancing": "least-connections",
      "targets": [
        {"url": "https://example.com", "weight": 1, "slowStartMs": 30000, "maxConnections": 32},
        {"url": "https://example.net", "weight": 1, "backup": true, "maxConnections": 32}
      ],
      "connectTimeoutMs": 5000,
      "requestTimeoutMs": 30000,
      "maxConnections": 64,
      "maxIdleConnections": 16,
      "maxResponseHeaderBytes": 65536,
      "maxResponseHeaders": 100,
      "idleConnectionTimeoutMs": 60000,
      "maxInFlightRequests": 256,
      "retry": {
        "maxAttempts": 2,
        "timeoutMs": 30000,
        "retryOn": ["error", "timeout", "http_502", "http_503", "http_504"]
      }
    }
  ],
  "virtualHosts": [
    {
      "id": "example-web",
      "listenerRefs": ["public-http"],
      "serverNames": ["localhost"],
      "routes": [
        {
          "id": "health",
          "match": {
            "pathType": "exact",
            "path": "/healthz",
            "methods": ["GET", "HEAD"]
          },
          "resourceRef": "health-response"
        },
        {
          "id": "upstream-example",
          "match": {
            "pathType": "prefix",
            "path": "/upstream"
          },
          "resourceRef": "example-origin-proxy"
        },
        {
          "id": "web",
          "match": {
            "pathType": "prefix",
            "path": "/"
          },
          "resourceRef": "web-static"
        }
      ]
    }
  ],
  "observability": {
    "accessLog": true
  },
  "deployment": {
    "drainTimeoutMs": 30000,
    "reload": {
      "mode": "watch",
      "pollIntervalMs": 1000
    },
    "resourcePressure": {
      "sampleIntervalMs": 250,
      "maximumProcessMemoryBytes": 1073741824,
      "memoryReserveBytes": 67108864,
      "memoryAdmissionPercent": 90,
      "memoryRecoveryPercent": 80,
      "maximumOpenHandles": 16384,
      "openHandleReserve": 128,
      "openHandleAdmissionPercent": 90,
      "openHandleRecoveryPercent": 80,
      "eventLoopLagAdmissionMs": 250,
      "eventLoopLagRecoveryMs": 50,
      "consecutivePressureSamples": 2,
      "consecutiveRecoverySamples": 4,
      "operationsReserveRequests": 16,
      "sampleFailurePolicy": "fail-closed"
    }
  },
  "metadata": {
    "owner": "sdkwork"
  }
}
