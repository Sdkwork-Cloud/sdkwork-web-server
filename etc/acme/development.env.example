# ACME / certificate defaults for development (safe checked-in example)
# Copy to .env.local and adjust; never commit secrets.

SDKWORK_WEB_ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory
SDKWORK_WEB_ACME_PROFILE=staging
SDKWORK_WEB_ACME_CONTACT_EMAIL=admin@localhost
SDKWORK_WEB_ACME_WEBROOT=./target/acme-webroot
SDKWORK_WEB_ACME_OPERATION_TIMEOUT_MS=180000
SDKWORK_WEB_CERT_LIVE_ROOT=./target/certs/live
SDKWORK_WEB_CERT_RENEW_BEFORE_DAYS=30
SDKWORK_WEB_CERT_ENCRYPTION_KEY=development-only-change-me

# Edge / nginx (disable on Windows dev without nginx installed)
SDKWORK_WEB_NGINX_ENABLED=false
SDKWORK_WEB_NGINX_SITES_ROOT=./target/nginx/sites-enabled/sdkwork
